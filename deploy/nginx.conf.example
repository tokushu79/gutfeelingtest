# Nginx server block for gutfeeling.uz
# Copy to /etc/nginx/sites-available/gutfeeling.uz on the VPS, then:
#   sudo ln -s /etc/nginx/sites-available/gutfeeling.uz /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
# Run `sudo certbot --nginx -d gutfeeling.uz -d www.gutfeeling.uz` afterwards —
# certbot will rewrite this file to add the HTTPS server block automatically.

server {
    listen 80;
    listen [::]:80;
    server_name gutfeeling.uz www.gutfeeling.uz;

    # Serve the built React app.
    root /var/www/gutfeelingtest/client/dist;
    index index.html;

    # React Router: any unmatched path falls back to index.html.
    location / {
        try_files $uri /index.html;
    }

    # Proxy API calls to the Node/Express process (managed by PM2).
    location /api/ {
        proxy_pass http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Reasonable cache headers for hashed static assets.
    location /assets/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}
